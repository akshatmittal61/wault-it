{
	"name": "wault-it",
	"description": "Store and secure passwords for everything, encrypted behind one paraphrase that only you remember.",
	"version": "0.1.1",
	"private": true,
	"engines": {
		"node": ">=18.0.0",
		"npm": "please-use-yarn",
		"yarn": ">=1.22.0"
	},
	"scripts": {
		"dev": "next dev",
		"build": "NODE_ENV=production next build",
		"start": "next start",
		"lint": "next lint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky install",
		"test": "echo \"Error: no test specified\" && exit 0",
		"clean": "rm -rf .next/ && rm -rf dist/ && rm -rf .cache/ && rm -rf .yarn/ && rm -rf coverage/",
		"reset": "yarn clean && rm -rf node_modules/ && rm -rf logs/",
		"clone:db": "bash scripts/db/clone.sh"
	},
	"dependencies": {
		"aos": "^2.3.4",
		"axios": "^1.6.7",
		"dayjs": "^1.11.20",
		"google-auth-library": "^10.5.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^8.18.0",
		"next": "14.1.0",
		"node-cache": "^5.1.2",
		"react": "^18",
		"react-dom": "^18",
		"react-hot-toast": "^2.4.1",
		"react-icons": "^5.0.1",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@commitlint/cli": "^18.6.1",
		"@commitlint/config-conventional": "^18.6.2",
		"@types/aos": "^3.0.7",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"eslint": "^8",
		"eslint-config-next": "14.1.0",
		"husky": "^9.0.11",
		"prettier": "^3.2.5",
		"sass": "^1.70.0",
		"typescript": "^5"
	}
}
